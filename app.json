{
  "expo": {
    "name": "Goal Grower",
    "slug": "goal-grower",
    "scheme": "goalgrower",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Goal_Grower_Logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Goal_Grower_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ziyu.goalgrower",
      "associatedDomains": [
        "applinks:goalgrower-2a859.firebaseapp.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ziyu.goalgrower",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Goal_Grower_Logo.png",
        "backgroundColor": "#ffffff"
      },
      "enableProguardInReleaseBuilds": true,
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "goalgrower-2a859.firebaseapp.com",
              "pathPrefix": "/__/auth/links"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "goalgrower-2a859.firebaseapp.com",
              "pathPrefix": "/__/auth/action"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "goalgrower"
            }
          ]
        }
      ],
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/Goal_Grower_Logo.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "16ddaa2a-f90c-4a59-9342-874b03e16819"
      }
    },
    "owner": "devaaj"
  }
}
